{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@loopback/build/config/tsconfig.common.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "Node16",
    "moduleResolution": "Node16",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src"
  ]
}
